#!/bin/bash

#########################################################################
# This file is managed centrally, any manual changes might be overwritten
#########################################################################

if tput setaf 1 &> /dev/null; then
  reset=$(tput sgr0);
  bold=$(tput bold);
  pink=$(tput setaf 163);
  violet=$(tput setaf 103);
  blue=$(tput setaf 38);
  cyan=$(tput setaf 72);
  green=$(tput setaf 41);
  yellow=$(tput setaf 172);
  orange=$(tput setaf 202);
  red=$(tput setaf 160);
  black=$(tput setaf 0);
  white=$(tput setaf 15);
  grey=$(tput setaf 245);
else
  reset="";
  bold='';
  black="";
  blue="";
  cyan="";
  green="";
  orange="";
  purple="";
  red="";
  violet="";
  white="";
  yellow="";
  grey="";
fi;
